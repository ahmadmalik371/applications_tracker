# Copy to backend/.env and fill in your local PostgreSQL credentials.
# Uses the locally installed PostgreSQL server (not Docker).

ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Local PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_ats

# SQLAlchemy async driver (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5433/ai_ats

# Redis (optional for later milestones)
REDIS_URL=redis://localhost:6379/0
