{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "title": "AI-ATS Application Metrics",
  "panels": [
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "title": "HTTP Request Latency (p95)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "title": "In-Progress Requests",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "http_requests_in_progress", "legendFormat": "in-progress"}
      ],
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8}
    },
    {
      "title": "Celery Task Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(celery_task_total[1m])",
          "legendFormat": "{{task}} {{status}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8}
    },
    {
      "title": "Celery Task Duration (p95)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(celery_task_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 duration"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 18, "y": 8}
    },
    {
      "title": "DB Pool Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "db_pool_connections_in_use", "legendFormat": "in use"}
      ],
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 16}
    }
  ],
  "schemaVersion": 27,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s"
}
